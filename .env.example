# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENV=development
APP_NAME=Team Task Board
SECRET_KEY=team-task-board-dev-secret-key-minimum-32-characters-long

# -----------------------------------------------------------------------------
# JWT / Authentication
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=team-task-board-dev-secret-key-minimum-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------------------------
# Authentication Rate Limiting
# -----------------------------------------------------------------------------
AUTH_RATE_LIMIT_TIMES=10
AUTH_RATE_LIMIT_SECONDS=60

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=ttb
POSTGRES_PASSWORD=ttb_password
POSTGRES_DB=ttb_db
POSTGRES_HOST=localhost
POSTGRES_PORT=55432

# Use this when running backend locally on your Mac:
DATABASE_URL=postgresql+asyncpg://ttb:ttb_password@localhost:55432/ttb_db

# If running backend inside Docker, Docker Compose should override it with:
# DATABASE_URL=postgresql+asyncpg://ttb:ttb_password@db:5432/ttb_db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

# Use this when running backend locally on your Mac:
REDIS_URL=redis://localhost:6380/0

# If running backend inside Docker, Docker Compose should override it with:
# REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# CORS / Frontend
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5174
FRONTEND_URL=http://localhost:5174

# -----------------------------------------------------------------------------
# Frontend Build-Time Variables
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8010/api/v1
VITE_WS_URL=ws://localhost:8010/api/v1/ws