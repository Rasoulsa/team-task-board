# ---- Backend ----
ENV=development
APP_NAME=Team Task Board
SECRET_KEY=change-me-super-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Postgres
POSTGRES_USER=ttb
POSTGRES_PASSWORD=ttb_password
POSTGRES_DB=ttb_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://ttb:ttb_password@db:5432/ttb_db

# Redis
REDIS_URL=redis://redis:6379/0

# CORS
CORS_ORIGINS=http://localhost:5173

# ---- Frontend ----
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/api/v1/ws
